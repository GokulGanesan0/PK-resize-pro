{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Poster Resize Pro",
  "version": "1.0.0",
  "identifier": "com.posterresizepro.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Poster Resize Pro",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/poster-resize-backend"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "allow": [
        {
          "name": "binaries/poster-resize-backend",
          "sidecar": true,
          "args": true
        },
        {
          "name": "python",
          "cmd": "python",
          "args": true
        }
      ]
    }
  }
}
