{
  "identifier": "default",
  "description": "Default capabilities for the application",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/poster-resize-backend",
          "sidecar": true
        },
        {
          "name": "python",
          "cmd": "python"
        }
      ]
    }
  ]
}
